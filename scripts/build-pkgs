        update_hashfile__168_v0 "${root_dir}" "${key}" "${version}" "sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
        ret_update_hashfile168_v0__100_16="${ret_update_hashfile168_v0}"
