        rm -f "${outfile_45}"
        __status=$?
        ret_build_package169_v0=0
        return 0
    fi
    rm -f "${outfile_45}"
    __status=$?
    echo_success__33_v0 "Build successful (no hash update needed)"
    ret_build_package169_v0=1
    return 0
}

hash_needs_build__173_v0() {
    local root_dir=$1
    local hash_key=$2
    local package_version=$3
    get_hostname__40_v0 
    hostname_27="${ret_get_hostname40_v0}"
    get_hashfile_path__39_v0 "${root_dir}" "${hostname_27}"
    hashfile_28="${ret_get_hashfile_path39_v0}"
    fake_hash_29="sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
    query_30="
.[ \$key ] as \$entry |
if
  (\$entry == null)
  or ((\$entry | type) "'!'"= \"object\")
  or ((\$entry.version // \"\") == \"\")
  or ((\$entry.hash // \"\") == \"\")
  or (\$entry.hash == \$fake)
  or (\$entry.version "'!'"= \$version)
then
  \"1\"
else
  \"0\"
end
"
    command_17="$(jq -r             --arg key "${hash_key}"             --arg version "${package_version}"             --arg fake "${fake_hash_29}"             "${query_30}"             "${hashfile_28}")"
    __status=$?
    result_31="${command_17}"
    ret_hash_needs_build173_v0="$([ "_${result_31}" != "_1" ]; echo $?)"
    return 0
}

