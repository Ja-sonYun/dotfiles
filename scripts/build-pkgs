        update_hashfile__168_v0 "${root_dir}" "${key}" "${version}" "${new_hash_50}"
        ret_update_hashfile168_v0__120_16="${ret_update_hashfile168_v0}"
        if [ "$(( ! ${ret_update_hashfile168_v0__120_16} ))" != 0 ]; then
            echo_error__35_v0 "Failed to update hashfile"
            ret_build_package169_v0=0
            return 0
