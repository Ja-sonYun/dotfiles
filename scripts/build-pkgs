            echo_error__35_v0 "Rebuild still failed after hash update"
            cat "${rebuild_out_51}" >&2
            __status=$?
            rm -f "${rebuild_out_51}"
            __status=$?
            ret_build_package169_v0=0
            return 0
        fi
        output_has__166_v0 "${rebuild_out_51}" "error:"
        ret_output_has166_v0__135_12="${ret_output_has166_v0}"
