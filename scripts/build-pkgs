update_hashfile__168_v0() {
    local root_dir=$1
    local key=$2
    local version=$3
    local hash=$4
    get_hostname__40_v0 
    hostname_32="${ret_get_hostname40_v0}"
    get_hashfile_path__39_v0 "${root_dir}" "${hostname_32}"
    hashfile_33="${ret_get_hashfile_path39_v0}"
    debug__136_v0 "Updating hashfile: ${hashfile_33}"
    debug__136_v0 "Hostname: ${hostname_32}, Key: ${key}, Version: ${version}, Hash: ${hash}"
    query_34="
.[ \$key ].version = \$version |
.[ \$key ].hash = \$hash
"
    command_16="$(jq             --arg key "${key}"             --arg version "${version}"             --arg hash "${hash}"             "${query_34}"             "${hashfile_33}")"
    __status=$?
    updated_35="${command_16}"
    if [ "$([ "_${updated_35}" != "_" ]; echo $?)" != 0 ]; then
        ret_update_hashfile168_v0=0
        return 0
    fi
    echo "${updated_35}" > "${hashfile_33}"
    __status=$?
    ret_update_hashfile168_v0=1
    return 0
}

build_package__169_v0() {
    local root_dir=$1
    local file=$2
    local key=$3
    local version=$4
    local force=$5
    if [ "${force}" != 0 ]; then
