    local file=$2
    debug__140_v0 "sed_inplace on ${file}: ${script}"
    command_9="$(sed --version 2>&1 | head -1 || echo "")"
    __status=$?
    gnu_check_43="${command_9}"
    if [ "$([ "_${gnu_check_43}" == "_" ]; echo $?)" != 0 ]; then
        sed -i -e "${script}" "${file}"
        __status=$?
        if [ "${__status}" != 0 ]; then
            ret_sed_inplace160_v0=''
            return "${__status}"
        fi
    else
        sed -i '' -e "${script}" "${file}"
        __status=$?
        if [ "${__status}" != 0 ]; then
            ret_sed_inplace160_v0=''
            return "${__status}"
        fi
    fi
}

