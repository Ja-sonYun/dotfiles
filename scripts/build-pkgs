    local attr=$2
    command_5="$(sed -n 's/^[[:space:]]*'"${attr}"'[[:space:]]*=[[:space:]]*"\([^"]*\)";.*/\1/p' "${file}")"
    __status=$?
    values_20="${command_5}"
    command_6="$(printf '%s
' "${values_20}" | sed '/^$/d' | wc -l | tr -d ' ')"
    __status=$?
    count_21="${command_6}"
    if [ "$([ "_${count_21}" == "_1" ]; echo $?)" != 0 ]; then
        echo_error__145_v0 "Expected exactly one ${attr} in ${file}, found ${count_21}"
        exit 1
    fi
    command_7="$(printf '%s
' "${values_20}" | sed '/^$/d' | head -n1)"
    __status=$?
    value_22="${command_7}"
    debug__140_v0 "Extracted ${attr}: ${value_22}"
    ret_extract_single_attr147_v0="${value_22}"
    return 0
}

