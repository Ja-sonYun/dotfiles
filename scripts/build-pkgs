            __status=$?
            rm -f "${rebuild_out_51}"
            __status=$?
            ret_build_package169_v0=0
            return 0
        fi
        rm -f "${rebuild_out_51}"
        __status=$?
        echo_success__33_v0 "Rebuild successful"'!'""
        ret_build_package169_v0=1
        return 0
    fi
    if [ "${has_error_48}" != 0 ]; then
        echo_error__35_v0 "Build failed"
        cat "${outfile_45}" >&2
