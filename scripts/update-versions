process_npm_file__158_v0() {
    local update_flag=$1
    local file=$2
    extract_single_attr__152_v0 "${file}" "packageName"
    package_name_27="${ret_extract_single_attr152_v0}"
    extract_single_attr__152_v0 "${file}" "packageVersion"
    package_version_28="${ret_extract_single_attr152_v0}"
    latest_npm_version__157_v0 "${package_name_27}"
    latest_37="${ret_latest_npm_version157_v0}"
    if [ "$(( $(( $([ "_${latest_37}" == "_" ]; echo $?) && $([ "_${latest_37}" == "_null" ]; echo $?) )) && $([ "_${latest_37}" == "_${package_version_28}" ]; echo $?) ))" != 0 ]; then
        sed_script_38="s|^\\([[:space:]]*packageVersion[[:space:]]*=[[:space:]]*\\)\"[^\"]*\";|\\1\"${latest_37}\";|"
