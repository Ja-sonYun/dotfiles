extract_single_attr__152_v0() {
    local file=$1
    local attr=$2
    command_10="$(sed -n 's/^[[:space:]]*'"${attr}"'[[:space:]]*=[[:space:]]*"\([^"]*\)";.*/\1/p' "${file}")"
    __status=$?
    values_23="${command_10}"
    command_11="$(printf '%s
' "${values_23}" | sed '/^$/d' | wc -l | tr -d ' ')"
    __status=$?
    count_24="${command_11}"
    if [ "$([ "_${count_24}" == "_1" ]; echo $?)" != 0 ]; then
        echo_error__150_v0 "Expected exactly one ${attr} in ${file}, found ${count_24}"
        exit 1
    fi
    command_12="$(printf '%s
' "${values_23}" | sed '/^$/d' | head -n1)"
    __status=$?
    value_25="${command_12}"
    debug__140_v0 "Extracted ${attr}: ${value_25}"
    ret_extract_single_attr152_v0="${value_25}"
    return 0
}

