{
  "name": "pi-permission-checker-local",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "tree-sitter-bash": "^0.25.1",
    "web-tree-sitter": "^0.26.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "scripts": {
    "check": "tsc --noEmit --allowImportingTsExtensions --moduleResolution bundler --module esnext --target es2022 --skipLibCheck index.ts test/*.test.ts",
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
