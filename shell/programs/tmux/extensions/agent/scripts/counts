#!/usr/bin/env bash

format_counts() {
	local idle="$1" running="$2" waiting="$3" display=""
	((idle > 0)) && display="#[bg=color244,fg=black]$idle#[default]"
	((running > 0)) && display+="${display:+:}#[bg=yellow,fg=black]$running#[default]"
	((waiting > 0)) && display+="${display:+:}#[bg=red,fg=white]$waiting#[default]"
	[[ -z "$display" ]] || printf ' %s' "$display"
}

if [[ "${1:-}" == "--self-test" ]]; then
	set -e
	[[ "$(format_counts 0 0 0)" == "" ]]
	[[ "$(format_counts 1 0 0)" == " #[bg=color244,fg=black]1#[default]" ]]
	[[ "$(format_counts 0 1 0)" == " #[bg=yellow,fg=black]1#[default]" ]]
	[[ "$(format_counts 0 0 1)" == " #[bg=red,fg=white]1#[default]" ]]
	[[ "$(format_counts 2 2 2)" == " #[bg=color244,fg=black]2#[default]:#[bg=yellow,fg=black]2#[default]:#[bg=red,fg=white]2#[default]" ]]
	[[ "$(format_counts 2 0 2)" == " #[bg=color244,fg=black]2#[default]:#[bg=red,fg=white]2#[default]" ]]
	exit 0
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$script_dir/../../../scripts/lib/common"
tmux_lock __agent_counts_lock || exit

declare -A project_cache idle_counts running_counts waiting_counts
declare -A win_seen win_project_seen win_idle win_running win_waiting
declare -A win_old_counts
declare -a main_windows main_panes changed_windows

while IFS=$'\x1f' read -r session window_id path enabled project state old_counts monitor_scope; do
	[[ -n "$monitor_scope" ]] && continue
	if [[ "$session" != "_popup_all_agents" && "$enabled" == "1" && -n "$project" ]]; then
		case "$state" in
			idle) idle_counts[$project]=$((${idle_counts[$project]:-0} + 1)) ;;
			running) running_counts[$project]=$((${running_counts[$project]:-0} + 1)) ;;
			waiting | error) waiting_counts[$project]=$((${waiting_counts[$project]:-0} + 1)) ;;
		esac
	fi
	if [[ "$session" == "main" && -n "$path" ]]; then
		main_panes+=("$window_id"$'\x1f'"$path")
		if [[ -z "${win_seen[$window_id]:-}" ]]; then
			win_seen[$window_id]=1
			main_windows+=("$window_id")
			win_old_counts[$window_id]="$old_counts"
		fi
	fi
done < <(tmux list-panes -a -F $'#{session_name}\x1f#{window_id}\x1f#{pane_current_path}\x1f#{@agent_enabled}\x1f#{@agent_project}\x1f#{@agent_state}\x1f#{@agent_counts_display}\x1f#{@pane_monitor_scope}' 2>/dev/null)

((${#main_windows[@]})) || exit 0

for entry in "${main_panes[@]}"; do
	window_id="${entry%%$'\x1f'*}"
	path="${entry#*$'\x1f'}"
	project="${project_cache[$path]:-}"
	if [[ -z "$project" ]]; then
		project="$(project_for_path "$path")"
		project_cache[$path]="$project"
	fi

	key="$window_id"$'\x1f'"$project"
	[[ -n "${win_project_seen[$key]:-}" ]] && continue
	win_project_seen[$key]=1

	win_idle[$window_id]=$((${win_idle[$window_id]:-0} + ${idle_counts[$project]:-0}))
	win_running[$window_id]=$((${win_running[$window_id]:-0} + ${running_counts[$project]:-0}))
	win_waiting[$window_id]=$((${win_waiting[$window_id]:-0} + ${waiting_counts[$project]:-0}))
done

tmux_begin
changed=0

for window_id in "${main_windows[@]}"; do
	idle="${win_idle[$window_id]:-0}"
	running="${win_running[$window_id]:-0}"
	waiting="${win_waiting[$window_id]:-0}"
	display="$(format_counts "$idle" "$running" "$waiting")"

	if [[ "$display" != "${win_old_counts[$window_id]}" ]]; then
		tmux_add set-option -w -q -t "$window_id" @agent_counts_display "$display"
		changed_windows+=("$window_id")
		changed=1
	fi
done

((changed)) || exit 0
if ! tmux_flush; then
	for window_id in "${changed_windows[@]}"; do
		tmux display-message -pt "$window_id" '#{window_id}' >/dev/null 2>&1 || exit 0
	done
	exit 1
fi
tmux_refresh_clients
