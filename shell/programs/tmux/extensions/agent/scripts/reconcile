#!/usr/bin/env bash

# codex only: claude/pi TUIs expose no reliable pane markers, their hooks self-heal.

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

running_re='esc to interrupt|ctrl\+c to interrupt'
waiting_re='(❯|›) *[0-9]+\.'
idle_re='context [0-9]+% left|worked for [0-9]'

detect_state() {
	if grep -qiE "$waiting_re" <<<"$1"; then
		printf 'waiting'
	elif grep -qiE "$running_re" <<<"$1"; then
		printf 'running'
	elif grep -qiE "$idle_re" <<<"$1"; then
		printf 'idle'
	fi
}

while IFS=$'\x1f' read -r pane_id session_id session_name enabled state in_mode name; do
	[[ "$session_name" != "_popup_all_agents" ]] || continue
	[[ "$enabled" == "1" && "$in_mode" == "0" && "$name" == "codex" ]] || continue
	content="$(tmux capture-pane -p -t "$pane_id" 2>/dev/null | grep -v '^[[:space:]]*$' | tail -n 30)"
	[[ -n "$content" ]] || continue
	detected="$(detect_state "$content")"
	[[ -n "$detected" && "$detected" != "$state" ]] || continue
	"$script_dir/status" "$detected" "$pane_id" "$session_id" || exit
done < <(tmux list-panes -a -F $'#{pane_id}\x1f#{session_id}\x1f#{session_name}\x1f#{@agent_enabled}\x1f#{@agent_state}\x1f#{pane_in_mode}\x1f#{@agent_name}' 2>/dev/null)
